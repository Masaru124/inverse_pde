# Python virtual environments
.venv/
.venv311/
venv/
env/

# Python caches and bytecode
__pycache__/
*.py[cod]
*$py.class

# Test/type/lint/notebook caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# OS/editor noise
.DS_Store
Thumbs.db
.vscode-test/

# Runtime logs and temp files
*.log
*.tmp

# Generated datasets and local benchmarks
data/generated/
data/_bench_gpu/

# Training and evaluation artifacts
outputs*/
results*/

# Deployment-required artifacts (allowlist)
!outputs_recovery_gpu_fast_stable/
outputs_recovery_gpu_fast_stable/*
!outputs_recovery_gpu_fast_stable/checkpoints/
outputs_recovery_gpu_fast_stable/checkpoints/*
!outputs_recovery_gpu_fast_stable/checkpoints/epoch_006_val_nll_-0.618860.pt

!results_recovery_gpu_fast_stable_quick_full_v3/
results_recovery_gpu_fast_stable_quick_full_v3/*
!results_recovery_gpu_fast_stable_quick_full_v3/metrics.json
!results_recovery_gpu_fast_stable_quick_full_v3/missing_claim_checks.json

# Checkpoints and binary tensors under generated artifact roots
outputs*/**/*.pt
data/generated/**/*.pt
data/_bench_gpu/**/*.pt

# Experiment tracking artifacts
wandb/
mlruns/
tensorboard/
events.out.tfevents*
